# Sanity Project Config
# Get these from sanity.io/manage after creating your project
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Sanity API Token (read-only for frontend, write for Studio)
# Generate at sanity.io/manage > API > Tokens
SANITY_API_READ_TOKEN=your_read_token_here

# ISR Revalidation Secret
# Generate a random string: openssl rand -base64 32
SANITY_REVALIDATE_SECRET=your_revalidation_secret_here

# Site URL (used for OG images and canonical URLs)
NEXT_PUBLIC_SITE_URL=https://dortibox.com
